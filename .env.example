# ============================================================
#  NBH Engineering Solutions — Environment Variables
#  Copy this file to .env.local and fill in the values.
#  NEVER commit .env.local to git.
# ============================================================

# ── APP ─────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://nbh-engineering.com
NEXT_PUBLIC_SITE_NAME="NBH Engineering Solutions"

# ── AI (Claude / Anthropic) ──────────────────────────────────
# Used by the project-intake chatbot and the lead-analysis AI agent
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# ── N8N (Automation & AI Agents) ────────────────────────────
# Public-facing webhook (used by the contact form → N8N)
N8N_WEBHOOK_URL=https://n8n.your-domain.com/webhook/nbh-contact
N8N_WEBHOOK_SECRET=your_n8n_webhook_secret_here

# N8N API (used by Next.js to trigger workflows programmatically)
N8N_BASE_URL=https://n8n.your-domain.com
N8N_API_KEY=your_n8n_api_key_here

# ── INTERNAL SECRETS (server-to-server calls) ────────────────
# Secret for /api/n8n/trigger endpoint (internal use)
TRIGGER_SECRET=your_internal_trigger_secret_32chars
# Secret for /api/deploy/trigger endpoint (called by N8N)
DEPLOY_WEBHOOK_SECRET=your_deploy_webhook_secret_32chars

# ── EMAIL (SMTP / Resend / SendGrid) ────────────────────────
# Option A: SMTP (e.g. Gmail, Zoho, custom)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=nevet@nbh-engineering.com
SMTP_PASS=your_smtp_app_password

# Option B: Resend API (recommended)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=nevet@nbh-engineering.com
EMAIL_TO=nevet@nbh-engineering.com

# Option C: SendGrid
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxx

# ── WHATSAPP — WAHA (WhatsApp HTTP API on Coolify) ──────────
# Self-hosted WAHA instance deployed on Coolify
WAHA_BASE_URL=https://waha.your-domain.com
WAHA_API_KEY=your_waha_api_key
WAHA_SESSION=default
# The WhatsApp number to receive lead notifications (with country code, no +)
WAHA_TO_NUMBER=972500000000
# Send from this number (must be authenticated in WAHA dashboard)
WAHA_FROM_NUMBER=972500000000

# ── NETLIFY ──────────────────────────────────────────────────
NETLIFY_SITE_ID=your-netlify-site-id
NETLIFY_AUTH_TOKEN=your_netlify_personal_access_token
# Build hook URLs — create at: Netlify → Site → Build & Deploy → Build hooks
NETLIFY_DEPLOY_HOOK=https://api.netlify.com/build_hooks/your_production_hook_id
NETLIFY_DEPLOY_HOOK_STAGING=https://api.netlify.com/build_hooks/your_staging_hook_id
# Used by N8N auto-deploy workflow to call the hook directly
NETLIFY_BUILD_HOOK_ID=your_production_hook_id

# ── GITHUB (Auto-commit & Deploy dispatch) ────────────────────
# PAT with repo + workflow permissions
GITHUB_PAT=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_REPO_OWNER=kfischi
GITHUB_REPO_NAME=NBH-Design

# ── CLOUDINARY (Media / Image Management) ───────────────────
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
# Upload preset (unsigned, for client-side uploads)
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=nbh_portfolio

# ── CRM — Notion (canonical) ────────────────────────────────
# Notion is the single source of truth for leads.
# Required columns in the Leads database (case-sensitive):
#   Name (title), Company (rich_text), Phone (phone_number),
#   Challenge (rich_text), Status (select), Source (select),
#   Date (date), AI Score (number, optional), AI Summary (rich_text, optional)
NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxx
NOTION_LEADS_DATABASE_ID=your_notion_database_id

# ── ADMIN PANEL ──────────────────────────────────────────────
# NextAuth.js (for protecting the /admin route)
NEXTAUTH_URL=https://nbh-engineering.com
NEXTAUTH_SECRET=your_nextauth_secret_min_32_chars

# Admin credentials (basic auth fallback)
ADMIN_EMAIL=admin@nbh-engineering.com
ADMIN_PASSWORD_HASH=$2b$12$your_bcrypt_hashed_password

# ── ANALYTICS ────────────────────────────────────────────────
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX
NEXT_PUBLIC_HOTJAR_ID=1234567

# ── RATE LIMITING (Upstash Redis) ────────────────────────────
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token
